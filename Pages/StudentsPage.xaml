<Page x:Class="stud.StudentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StudentsPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,0,0,10">
            <Button x:Name="BtnAdd" 
                    Content="➕ Добавить" 
                    Click="BtnAdd_Click"
                    Background="Green" 
                    Foreground="White"
                    Padding="10,5"
                    Margin="0,0,10,0"/>
            <Button x:Name="BtnEdit" 
                    Content="✏️ Редактировать" 
                    Click="BtnEdit_Click"
                    Background="Orange" 
                    Foreground="White"
                    Padding="10,5"
                    Margin="0,0,10,0"/>
            <Button x:Name="BtnDelete" 
                    Content="🗑 Удалить" 
                    Click="BtnDelete_Click"
                    Background="Red" 
                    Foreground="White"
                    Padding="10,5"/>
        </StackPanel>

        <DataGrid x:Name="DgStudents" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Margin="0,10"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_Stud}" Width="50"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Surname}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronumic}" Width="120"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding Date_Birthday, StringFormat='dd.MM.yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Группа" Binding="{Binding Group.Number}" Width="80"/>
                <DataGridTextColumn Header="Специальность" Binding="{Binding Group.Speciality.Name_Speciality}" Width="150"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login_Password_Stud.Login}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="TblCount" 
                   Grid.Row="2"
                   HorizontalAlignment="Left"
                   Margin="5"/>
    </Grid>
</Page>
<Page x:Class="stud.Pages.AddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавление нового студента" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="10"/>

        <StackPanel Grid.Row="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="350">

            <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    HorizontalAlignment="Center" 
                    Margin="5">
                <Image x:Name="IPicture" 
                       MaxHeight="150" 
                       MinHeight="100" 
                       Margin="5"
                       Stretch="Uniform"/>
            </Border>

            <Button x:Name="BtnAddImage" 
                    Content="Выбрать фото" 
                    Click="BtnAddImage_Click"
                    Background="Gray" 
                    Foreground="White"
                    Margin="0,5"/>

            <WrapPanel Margin="0,5">
                <TextBlock Text="Фамилия:" Width="80"/>
                <TextBox x:Name="TxtSurname" Width="250"/>
            </WrapPanel>

            <WrapPanel Margin="0,5">
                <TextBlock Text="Имя:" Width="80"/>
                <TextBox x:Name="TxtName" Width="250"/>
            </WrapPanel>

            <WrapPanel Margin="0,5">
                <TextBlock Text="Отчество:" Width="80"/>
                <TextBox x:Name="TxtPatronumic" Width="250"/>
            </WrapPanel>

            <WrapPanel Margin="0,5">
                <TextBlock Text="Группа:" Width="80"/>
                <ComboBox x:Name="CmbxGroup" 
                          Width="150"
                          DisplayMemberPath="Number"/>
            </WrapPanel>

            <WrapPanel Margin="0,5">
                <TextBlock Text="Специальность:" Width="80"/>
                <TextBox x:Name="TxtSpec" 
                         IsReadOnly="True" 
                         Width="250"
                         Background="LightGray"/>
            </WrapPanel>

            <WrapPanel Margin="0,5">
                <TextBlock Text="Дата рождения:" Width="80"/>
                <DatePicker x:Name="DpBirthday" Width="150"/>
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="10">
            <Button x:Name="BtnAdd" 
                    Content="Добавить" 
                    Click="BtnAdd_Click"
                    Background="Green" 
                    Foreground="White"
                    Padding="20,8"
                    Margin="5"/>
            <Button x:Name="BtnBack" 
                    Content="Назад" 
                    Click="BtnBack_Click"
                    Background="Gray" 
                    Foreground="White"
                    Padding="20,8"
                    Margin="5"/>
        </StackPanel>
</Grid>
</Page>